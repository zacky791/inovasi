# Production (Render) — use External host from local machine
DB_HOST=dpg-xxxxx-a.singapore-postgres.render.com
DB_PORT=5432
DB_USER=your_render_user
DB_PASSWORD=your_render_password
DB_NAME=your_render_db
DB_SSL=true
# Optional: full URL (preferred on Render Web Service)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

OPENAI_API_KEY=your_openai_api_key_here
UPLOAD_DIR=uploads
